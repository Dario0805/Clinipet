<%@page contentType="text/html" pageEncoding="UTF-8"%>
<!doctype html><html lang="es"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Registro | CliniPet</title><link href="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta20/dist/css/tabler.min.css" rel="stylesheet"><link href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" rel="stylesheet"><link href="https://fonts.googleapis.com/css2?family=Nunito:wght@500;700;800;900&family=Fredoka:wght@600;700&display=swap" rel="stylesheet"><style>body{min-height:100vh;display:grid;place-items:center;background:linear-gradient(135deg,#003d25,#00c875);font-family:Nunito,sans-serif}.cardx{width:min(480px,92%);background:white;border-radius:34px;padding:34px;box-shadow:0 35px 90px rgba(0,0,0,.25)}h1{font-family:Fredoka,sans-serif;color:#003d25}.form-control{border-radius:16px;padding:13px}.btn-main{border:0;border-radius:18px;background:linear-gradient(135deg,#00c875,#00f5a0);color:#003d25;font-weight:900;padding:13px 18px;width:100%}</style></head><body><div class="cardx"><h1><i class="ti ti-paw text-success"></i> Crear cuenta</h1><p class="text-secondary fw-bold">Regístrate para comprar y agendar citas.</p><% if(request.getAttribute("error")!=null){ %><div class="alert alert-danger"><%= request.getAttribute("error") %></div><% } %><form method="post" action="${pageContext.request.contextPath}/registro"><label class="form-label fw-bold">Nombre</label><input class="form-control mb-3" name="nombre" required><label class="form-label fw-bold">Documento</label><input class="form-control mb-3" name="documento" required><label class="form-label fw-bold">Telefono</label><input class="form-control mb-3" name="telefono" required><label class="form-label fw-bold">Direccion</label><input class="form-control mb-3" name="direccion" required><label class="form-label fw-bold">Correo</label><input class="form-control mb-3" type="email" name="correo" required><label class="form-label fw-bold">Contraseña</label><input class="form-control mb-4" type="password" name="contrasena" required><button class="btn-main">Registrarme</button></form><a class="d-block text-center mt-3 fw-bold text-success" href="${pageContext.request.contextPath}/login">Ya tengo cuenta</a></div></body></html>
